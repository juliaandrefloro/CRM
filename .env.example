# =============================================
# CRM TAROT — Configurações
# =============================================
# Copie este arquivo para .env e preencha os valores

# Banco de dados PostgreSQL
# Use o Supabase (gratuito): supabase.com → Settings → Database → Connection string
DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco

# Chave da API Anthropic (para o Agente Oráculo com IA)
# Obtenha em: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# API do Asaas (para geração de Pix)
# Obtenha em: asaas.com → Configurações → Integrações
ASAAS_API_KEY=sua_chave_asaas
ASAAS_WEBHOOK_TOKEN=token_secreto_que_voce_escolhe

# Porta do servidor (padrão: 3000)
PORT=3000
